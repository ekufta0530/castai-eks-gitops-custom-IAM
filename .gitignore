# Local variable files with secrets — use terraform.tfvars.example as the template
tf.vars
*.tfvars
!terraform.tfvars.example

# Backup generated by generate_tfvars.sh
*.tfvars.bak
tf.vars.bak

# Terraform state — contains sensitive outputs (tokens, ARNs, IDs)
terraform.tfstate
terraform.tfstate.backup
.terraform/
.terraform.lock.hcl
